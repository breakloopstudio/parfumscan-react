    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@react-native-community/cli": "^19.0.0",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.10",
    "firebase-admin": "^14.2.0",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.2",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "env:setup": "node -e \"const fs=require('fs');const p='.env';if(!fs.existsSync(p)){fs.copyFileSync('.env.example',p);console.log('✅ .env créé depuis .env.example');}else{console.log('⚠️  .env existe déjà, rien fait.');}\"",
    "functions:install": "cd functions && npm install",
    "functions:build": "cd functions && npm run build",
    "functions:deploy": "firebase deploy --only functions",
    "clean-data": "tsx scripts/clean-apify.ts",
    "import-data": "tsx scripts/import-firestore.ts",
    "migrate-search": "tsx scripts/migrate-search-keywords.ts",
    "clean-fragella": "tsx scripts/clean-fragella.ts",
    "migrate-webp": "tsx scripts/migrate-to-webp.ts",
    "migrate-bg": "tsx scripts/migrate-bgremoval.ts",
    "emulators": "firebase emulators:start",
    "test": "jest --watchAll",
    "test:ci": "jest --ci --coverage"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@react-native-firebase/.*|react-native-reanimated|react-native-gesture-handler|react-native-svg|@react-native-vector-icons)"
    ],
    "setupFilesAfterEnv": [
      "./jest-setup.js"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/dist/",
      "<rootDir>/android/",
      "<rootDir>/data/"
    ]
  },
  "private": true,
  "allowScripts": {
    "onnxruntime-node@1.27.0": true,
    "onnxruntime-node@1.17.3": true,
    "sharp@0.32.6": true,
    "sharp@0.35.3": true
  }
}
