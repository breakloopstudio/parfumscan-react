# ─── Firebase Emulators (développement local) ──────────────────────
# Décommente les 5 lignes ci-dessous pour connecter l'app
# aux émulateurs Firebase locaux au lieu de la production.
#
# ⚠️  Sur device physique Android/iOS, remplace "localhost"
#     par l'IP locale de ton PC (ex: 192.168.1.42).
#     "localhost" depuis un device Android pointe vers l'émulateur
#     Android intégré, pas vers ton PC.

# EXPO_PUBLIC_USE_EMULATORS=true
# EXPO_PUBLIC_FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# EXPO_PUBLIC_FIRESTORE_EMULATOR_HOST=localhost:8080
# EXPO_PUBLIC_FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199
# EXPO_PUBLIC_FIREBASE_FUNCTIONS_EMULATOR_HOST=localhost:5001
