    "expo-file-system": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-image-picker": "~57.0.4",
    "expo-keep-awake": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-location": "~57.0.5",
    "expo-navigation-bar": "~57.0.2",
    "expo-router": "~57.0.6",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~57.0.4",
